# App
NEXT_PUBLIC_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: force Stripe Price IDs instead of inline price_data
STRIPE_REQUIRE_PRICE_IDS=false
# Optional per-course Price IDs (slug uppercased with underscores)
# STRIPE_PRICE_ID_CPR_AED=
# STRIPE_PRICE_ID_FIRST_AID=
# STRIPE_PRICE_ID_BLS=
# STRIPE_PRICE_ID_OPIOID_OVERDOSE_RESPONSE=
# STRIPE_PRICE_ID_HEMORRHAGE_CONTROL=
# STRIPE_PRICE_ID_DE_ESCALATION=
# STRIPE_PRICE_ID_WORKPLACE_VIOLENCE_PREVENTION=
# STRIPE_PRICE_ID_ACTIVE_SHOOTER_PREPAREDNESS=
# STRIPE_PRICE_ID_EMERGENCY_MANAGEMENT_HEALTHCARE=
# STRIPE_PRICE_ID_ICS_HICS=
# STRIPE_PRICE_ID_OSHA_SAFETY=
# STRIPE_PRICE_ID_BLOODBORNE_PATHOGENS=

# SMTP (required in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@nyxpulse.com
SMTP_FROM_NAME=NyxPulse
SMTP_REQUIRED=false
# Optional smoke-test token for POST /api/test-email (header: x-smtp-test-token)
# Leave unset in production to disable the endpoint.
SMTP_TEST_TOKEN=

# Contact / leads
CONTACT_INBOX_EMAIL=sales@nyxpulse.com
CONTACT_LEADS_TOKEN=
# Optional absolute/relative path. Defaults to .data/contact-leads.ndjson
# CONTACT_LEADS_STORAGE_PATH=

# Firebase (Firestore via Admin SDK for progress, certificates, leads)
# Create a service account in Firebase Console → Project settings → Service accounts
FIREBASE_PROJECT_ID=nyxpulse
FIREBASE_CLIENT_EMAIL=
# Paste the full private key. On Vercel, keep \n escape sequences in one line.
FIREBASE_PRIVATE_KEY=

# Optional browser Firebase config (Analytics / future client features)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nyxpulse.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nyxpulse
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nyxpulse.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
